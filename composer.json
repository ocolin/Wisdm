{
    "name": "ocolin/wisdm",
    "description": "REST Client for WISDM Wireless API",
    "type": "library",
    "keywords": [
        "wisdm",
        "wireless",
        "rest",
        "api",
        "wisp"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "guzzlehttp/guzzle": "^7.10",
        "ocolin/global-type": "^2.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0",
        "ocolin/easyenv": "^3.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ocolin\\Wisdm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ocolin\\Wisdm\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Colin Miller",
            "email": "ocolin@cruzio.com"
        }
    ],
    "scripts": {
        "test": "vendor/bin/phpunit --no-coverage --display-deprecations --display-notices",
        "debug": "vendor/bin/phpunit --no-coverage --display-deprecations --display-notices --debug",
        "test-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-html coverage"
    }
}
